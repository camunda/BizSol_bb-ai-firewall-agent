<?xml version="1.0" encoding="UTF-8"?>
<!--
    Test-specific Logback config.
    Logback picks up logback-test.xml from the TEST classpath before
    logback-spring.xml, so this overrides the main config during tests.
-->
<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <!-- Suppress known noisy RDBMS history-cleanup error from Camunda container -->
        <filter class="io.camunda.bizsol.bb.ai_firewall_agent.config.MessageSubstringFilter">
            <substring>MessageSubscriptionMapper.updateHistoryCleanupDate</substring>
        </filter>
        <!-- Suppress JVM warnings about restricted/deprecated methods from connectors container -->
        <filter class="io.camunda.bizsol.bb.ai_firewall_agent.config.MessageSubstringFilter">
            <substring>WARNING: A terminally deprecated method</substring>
        </filter>
        <filter class="io.camunda.bizsol.bb.ai_firewall_agent.config.MessageSubstringFilter">
            <substring>WARNING: A restricted method</substring>
        </filter>
        <filter class="io.camunda.bizsol.bb.ai_firewall_agent.config.MessageSubstringFilter">
            <substring>WARNING: sun.misc.Unsafe::</substring>
        </filter>
        <filter class="io.camunda.bizsol.bb.ai_firewall_agent.config.MessageSubstringFilter">
            <substring>WARNING: Please consider reporting this</substring>
        </filter>
        <filter class="io.camunda.bizsol.bb.ai_firewall_agent.config.MessageSubstringFilter">
            <substring>WARNING: java.lang.System::loadLibrary</substring>
        </filter>
        <filter class="io.camunda.bizsol.bb.ai_firewall_agent.config.MessageSubstringFilter">
            <substring>WARNING: Use --enable-native-access</substring>
        </filter>
        <filter class="io.camunda.bizsol.bb.ai_firewall_agent.config.MessageSubstringFilter">
            <substring>WARNING: Restricted methods will be blocked</substring>
        </filter>
        <!-- Suppress logback deprecation warnings from connectors container -->
        <filter class="io.camunda.bizsol.bb.ai_firewall_agent.config.MessageSubstringFilter">
            <substring>condition' attribute in &lt;if&gt; element is deprecated</substring>
        </filter>
        <filter class="io.camunda.bizsol.bb.ai_firewall_agent.config.MessageSubstringFilter">
            <substring>conditionAttributeDeprecation</substring>
        </filter>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%-40.40logger{39}) │ %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Silence framework noise in tests -->
    <logger name="org.springframework"             level="WARN" />
    <logger name="io.camunda.client"               level="WARN" />
    <logger name="io.camunda.zeebe"                level="ERROR" />
    <logger name="io.camunda.process.test"         level="WARN" />

    <!-- Connectors runtime – show AI agent connector activity -->
    <logger name="io.camunda.connector"            level="WARN" />
    <logger name="io.camunda.connector.agenticai"  level="WARN" />

    <!-- Testcontainers / Docker -->
    <logger name="org.testcontainers"              level="WARN" />
    <logger name="tc"                              level="ERROR" />
    <logger name="tc.connectors"                   level="ERROR" />
    <logger name="com.github.dockerjava"           level="WARN" />

    <!-- gRPC / Netty -->
    <logger name="io.grpc"                         level="ERROR" />
    <logger name="io.netty"                        level="ERROR" />

    <!-- WireMock -->
    <logger name="wiremock"                        level="ERROR" />
    <logger name="com.github.tomakehurst"          level="ERROR" />

    <!-- Jackson / HTTP -->
    <logger name="com.fasterxml.jackson"           level="ERROR" />
    <logger name="org.apache.http"                 level="WARN" />
    <logger name="software.amazon"                 level="WARN" />

    <!-- Application code – keep verbose -->
    <logger name="io.camunda.bizsol"               level="DEBUG" />

    <root level="WARN">
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>
