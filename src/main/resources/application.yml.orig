
camunda:
  process-test:
    runtime-mode: remote
  client:
    mode: self-managed
    auth:
      method: none
    # grpc-address: http://host.docker.internal:26500
    grpc-address: http://localhost:26500
    # rest-address: http://host.docker.internal:8080
    rest-address: http://localhost:8080

# enable usage metrics
# https://docs.camunda.io/docs/apis-tools/camunda-spring-boot-starter/configuration/#observing-metrics
management:
  endpoints:
    web:
      exposure:
        include: metrics
spring:
  application:
    name: AI Firewall Agent