<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ─── Console appender with readable formatting ─── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!--
                Pattern breakdown:
                  %d{HH:mm:ss.SSS}  – timestamp (time only; drop the date for local dev)
                  %highlight(%-5level) – coloured INFO/WARN/ERROR/DEBUG
                  %cyan(%-40.40logger{39}) – shortened logger name, padded to 40 chars
                  %msg%n – the actual message
            -->
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%-40.40logger{39}) │ %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ─── Quiet the noisy framework loggers ─── -->

    <!-- Camunda SDK internals -->
    <logger name="io.camunda.client"              level="WARN" />
    <logger name="io.camunda.zeebe"               level="WARN" />
    <logger name="io.camunda.process.test"         level="INFO" />

    <!-- Spring Boot startup noise -->
    <logger name="org.springframework"             level="WARN" />
    <logger name="org.springframework.boot.web"    level="INFO" />

    <!-- Testcontainers / Docker (very chatty during CPT tests) -->
    <logger name="org.testcontainers"              level="WARN" />
    <logger name="tc"                              level="WARN" />
    <logger name="com.github.dockerjava"           level="WARN" />
    <logger name="docker.java"                     level="WARN" />

    <!-- Netty / gRPC transport -->
    <logger name="io.grpc"                         level="WARN" />
    <logger name="io.netty"                        level="WARN" />

    <!-- WireMock (used in tests) -->
    <logger name="wiremock"                        level="INFO" />
    <logger name="com.github.tomakehurst"          level="INFO" />

    <!-- ─── YOUR application code: always show everything ─── -->
    <logger name="io.camunda.bizsol"               level="DEBUG" />

    <!-- ─── Root level ─── -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>
