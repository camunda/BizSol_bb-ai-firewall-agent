    <bpmn:subProcess id="Activity_1p32q28" triggeredByEvent="true">
      <bpmn:startEvent id="Event_task-agent-failed" name="AI Agent Failed">
        <bpmn:outgoing>Flow_0qte4m9</bpmn:outgoing>
