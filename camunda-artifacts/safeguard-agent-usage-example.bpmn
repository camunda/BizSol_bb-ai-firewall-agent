<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.9.0">
  <bpmn:process id="safeguard-agent-usage" name="Safeguard Agent Usage Example" isExecutable="true">
    <bpmn:startEvent id="StartEvent" name="Process started">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent" targetRef="Activity_CallSafeguard" />
    <bpmn:callActivity id="Activity_CallSafeguard" name="Run AI Firewall on user prompt">
      <bpmn:extensionElements>
        <zeebe:calledElement processId="safeguard-agent" propagateAllChildVariables="false" propagateAllParentVariables="false" />
        <zeebe:ioMapping>
          <zeebe:input source="=userPromptToSafeguard" target="userPromptToSafeguard" />
          <zeebe:input source="=minConfidence" target="minConfidence" />
          <zeebe:input source="=maxTries" target="maxTries" />
          <zeebe:input source="=maxUserPromptSize" target="maxUserPromptSize" />
          <zeebe:output source="=safeGuardResult" target="safeGuardResult" />
          <zeebe:output source="=error" target="error" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Activity_CallSafeguard" targetRef="EndEvent" />
    <bpmn:endEvent id="EndEvent" name="Process ended">
      <bpmn:incoming>Flow_2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:subProcess id="Activity_0zp9oao" triggeredByEvent="true">
      <bpmn:startEvent id="Event_0gwnu04" name="Unexpected escalation caught">
        <bpmn:outgoing>Flow_1uajkqf</bpmn:outgoing>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_0dhns0d" />
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="Flow_1uajkqf" sourceRef="Event_0gwnu04" targetRef="Event_0p22u01" />
      <bpmn:endEvent id="Event_0p22u01" name="Create an incident">
        <bpmn:incoming>Flow_1uajkqf</bpmn:incoming>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_06u8usp" errorRef="Error_0hzgqp7" />
      </bpmn:endEvent>
    </bpmn:subProcess>
    <bpmn:subProcess id="Activity_0nrpgz5" triggeredByEvent="true">
      <bpmn:startEvent id="Event_max-user-input-exceeded" name="User prompt too large">
        <bpmn:outgoing>Flow_09683xp</bpmn:outgoing>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_1ssmhdh" escalationRef="Escalation_1njtpsk" />
      </bpmn:startEvent>
      <bpmn:endEvent id="Event_1baukk3" name="Create an incident">
        <bpmn:incoming>Flow_09683xp</bpmn:incoming>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_08xgp2w" errorRef="Error_13lra2n" />
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_09683xp" sourceRef="Event_max-user-input-exceeded" targetRef="Event_1baukk3" />
    </bpmn:subProcess>
    <bpmn:subProcess id="Activity_1fk0gob" triggeredByEvent="true">
      <bpmn:startEvent id="Event_max-iterations-reached" name="Limit of tries exceeded">
        <bpmn:outgoing>Flow_0dpglrq</bpmn:outgoing>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_0khtvmw" escalationRef="Escalation_2ahi254" />
      </bpmn:startEvent>
      <bpmn:endEvent id="Event_1iljptb" name="Create an incident">
        <bpmn:incoming>Flow_0dpglrq</bpmn:incoming>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_075b5j4" errorRef="Error_11ys6jo" />
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_0dpglrq" sourceRef="Event_max-iterations-reached" targetRef="Event_1iljptb" />
    </bpmn:subProcess>
    <bpmn:subProcess id="Activity_1p32q28" triggeredByEvent="true">
      <bpmn:extensionElements />
      <bpmn:startEvent id="Event_task-agent-failed" name="AI agent task failed">
        <bpmn:outgoing>Flow_0qte4m9</bpmn:outgoing>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_1j1cx41" escalationRef="Escalation_37b41id" />
      </bpmn:startEvent>
      <bpmn:sequenceFlow id="Flow_0qte4m9" sourceRef="Event_task-agent-failed" targetRef="Event_13jpl3c" />
      <bpmn:endEvent id="Event_13jpl3c" name="Create an incident">
        <bpmn:incoming>Flow_0qte4m9</bpmn:incoming>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_0t0dkra" errorRef="Error_0ip544g" />
      </bpmn:endEvent>
    </bpmn:subProcess>
    <bpmn:subProcess id="Activity_1l606vv" triggeredByEvent="true">
      <bpmn:startEvent id="Event_bad-agent-output" name="Agent output malformed">
        <bpmn:outgoing>Flow_18cvood</bpmn:outgoing>
        <bpmn:escalationEventDefinition id="EscalationEventDefinition_07dxpkd" escalationRef="Escalation_00qt6kg" />
      </bpmn:startEvent>
      <bpmn:endEvent id="Event_0ryz4lf" name="Create an incident">
        <bpmn:incoming>Flow_18cvood</bpmn:incoming>
        <bpmn:errorEventDefinition id="ErrorEventDefinition_0802zav" errorRef="Error_04z3q46" />
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_18cvood" sourceRef="Event_bad-agent-output" targetRef="Event_0ryz4lf" />
    </bpmn:subProcess>
    <bpmn:textAnnotation id="TextAnnotation_StartVariables">
      <bpmn:text>Start with only the required variable. Example:

{
  "userPromptToSafeguard":
    "What is the status of my insurance claim number IC-2024-001?"
}</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1" associationDirection="None" sourceRef="StartEvent" targetRef="TextAnnotation_StartVariables" />
    <bpmn:textAnnotation id="TextAnnotation_Result">
      <bpmn:text>Result in safeGuardResult:

{
  "decision": "allow",
  "risk_labels": [],
  "reasons": [...],
  "confidence": 0.9+
}</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_2" associationDirection="None" sourceRef="EndEvent" targetRef="TextAnnotation_Result" />
    <bpmn:textAnnotation id="TextAnnotation_071o76n">
      <bpmn:text>Escalations thrown from the AI Firewall agent can be used to steer the business process based on the outcome</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0wtjhxw" associationDirection="None" sourceRef="Activity_1l606vv" targetRef="TextAnnotation_071o76n" />
  </bpmn:process>
  <bpmn:error id="Error_0ellcg2" name="Error_AI_Firewall_Agent" errorCode="=get or else(error, &#34;Error_AI_Firewall_Agent&#34;)" />
  <bpmn:escalation id="Escalation_1njtpsk" name="catch_max-user-input-exceeded" escalationCode="safeguard_max-user-input-exceeded" />
  <bpmn:escalation id="Escalation_2ahi254" name="catch_max-iterations-reached" escalationCode="safeguard_max-iterations-reached" />
  <bpmn:escalation id="Escalation_37b41id" name="catch_task-agent-failed" escalationCode="safeguard_task-agent-failed" />
  <bpmn:escalation id="Escalation_2dprnft" name="catch_json-worker-error" escalationCode="safeguard_json-worker-error" />
  <bpmn:escalation id="Escalation_00qt6kg" name="catch_bad-agent-output" escalationCode="safeguard_bad-agent-output" />
  <bpmn:error id="Error_13lra2n" name="Prompt_too_large" errorCode="=get or else(&#10;  error,&#10;  &#34;User prompt exceeds maximum allowed size.&#10;&#10;Configured limit: &#34; + string(maxUserPromptSize) + &#34;&#10;Actual size: &#34; + string(userPromptSize) + &#34;&#10;&#10;Action:&#10;Modify the prompt or update the maxUserPromptSize configuration.&#34;&#10;)" />
  <bpmn:error id="Error_0ip544g" name="AI_agent_failed" errorCode="=get or else(&#10;  error,&#10;  &#34;AI agent could not complete prompt evaluation; verify AI provider configuration and connectivity&#34;&#10;)&#10;&#10;" />
  <bpmn:error id="Error_0hzgqp7" name="Call_activity_incident" errorCode="=get or else(&#10;  error,&#10;  &#34;Called activity could not complete prompt evaluation; review safeguard escalation details and incident logs to identify the root cause&#34;&#10;)" />
  <bpmn:error id="Error_11ys6jo" name="Max_iterations_reached" errorCode="=get or else(&#10;  error,&#10;  &#34;Safeguard evaluation failed after reaching the maximum retry limit; review safeguard prompts or adjust minConfidence or maxTries&#34;&#10;) " />
  <bpmn:error id="Error_04z3q46" name="JSON_output_error" errorCode="=get or else(&#10;  error,&#10;  &#34;Safeguard evaluation failed after reaching the maximum retry limit; review safeguard prompts or adjust minConfidence or maxTries&#34;&#10;)" />
