        <bpmn:errorEventDefinition id="ErrorEventDefinition_0802zav" errorRef="Error_0ellcg2" />
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_18cvood" sourceRef="Event_bad-agent-output" targetRef="Event_0ryz4lf" />
    </bpmn:subProcess>
    <bpmn:textAnnotation id="TextAnnotation_StartVariables">
      <bpmn:text>Start with only the required variable:
- userPromptToSafeguard: "What is the status of my insurance claim number IC-2024-001?"

Note: systemPrompt is optional; defaults to embedded template in safeguard-agent</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1" associationDirection="None" sourceRef="StartEvent_1" targetRef="TextAnnotation_StartVariables" />
    <bpmn:textAnnotation id="TextAnnotation_Result">
      <bpmn:text>Result in safeGuardResult:
{
  "decision": "allow",
  "risk_labels": [],
  "reasons": [...],
  "confidence": 0.9+
}</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_2" associationDirection="None" sourceRef="Event_End" targetRef="TextAnnotation_Result" />
  </bpmn:process>
