      <bpmn:outgoing>Flow_0lt0315</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_0x8hjc4" name="yes" sourceRef="Gateway_0clysfw" targetRef="Event_1tijisg">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=(is defined(responseJSON.decision) and is defined(responseJSON.confidence)) = true</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:textAnnotation id="TextAnnotation_0bwbzo7">
      <bpmn:text>send variables:
- "userPromptToSafeguard" for user prompt
- "systemPrompt" for system prompt</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_030ox7l" associationDirection="None" sourceRef="StartEvent_1" targetRef="TextAnnotation_0bwbzo7" />
    <bpmn:textAnnotation id="TextAnnotation_0jg8y9u">
      <bpmn:text>output should be in well-defined JSON for post-processing</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0cpp5na" associationDirection="None" sourceRef="Activity_1t4newl" targetRef="TextAnnotation_0jg8y9u" />
    <bpmn:textAnnotation id="TextAnnotation_0bumapk">
      <bpmn:text>safeGuardResult contains the result as a well defined JSON schema</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0g2yaw3" associationDirection="None" sourceRef="Event_1tijisg" targetRef="TextAnnotation_0bumapk" />
  </bpmn:process>
