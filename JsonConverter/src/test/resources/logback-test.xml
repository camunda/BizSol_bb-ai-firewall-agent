<?xml version="1.0" encoding="UTF-8"?>
<!--
    Test-specific Logback config.
    Logback picks up logback-test.xml from the TEST classpath before
    logback-spring.xml, so this overrides the main config during tests.
-->
<configuration>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%-40.40logger{39}) │ %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ─── Silence framework noise in tests ─── -->
    <logger name="org.springframework"             level="WARN" />
    <logger name="io.camunda.client"              level="WARN" />
    <logger name="io.camunda.zeebe"               level="WARN" />
    <logger name="io.camunda.process.test"         level="DEBUG" />

    <!-- Testcontainers / Docker – extremely chatty -->
    <logger name="org.testcontainers"              level="WARN" />
    <logger name="tc"                              level="WARN" />
    <logger name="com.github.dockerjava"           level="WARN" />

    <!-- gRPC / Netty -->
    <logger name="io.grpc"                         level="WARN" />
    <logger name="io.netty"                        level="WARN" />

    <!-- WireMock -->
    <logger name="wiremock"                        level="WARN" />
    <logger name="com.github.tomakehurst"          level="WARN" />

    <!-- Application code – keep verbose -->
    <logger name="io.camunda.bizsol"               level="DEBUG" />

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>
